# Connection to our own PostgreSQL database
POSTGRES_CONNECTION=postgresql://user:password@localhost:5432/your_database

# Connection to SyncHub's database (provided by SyncHub)
SYNCHUB_DB_CONNECTION=postgresql://your_synchub_user:your_password@synchub-db.database.windows.net:1433/your_db
SYNCHUB_SERVER=synchub-db.database.windows.net
SYNCHUB_DATABASE=your_db
SYNCHUB_USERNAME=your_synchub_user
SYNCHUB_PASSWORD=your_password

# Specify which schemas to sync (your connected services)
SCHEMAS_TO_SYNC=workflowmax2_13307_1

# Add prefix to table names
TABLE_PREFIX=synchub_

# Schedule
SYNC_SCHEDULE=0 2 * * *

# Sharepoint Excel file URLs (comma-separated if multiple)
EXCEL_FILE_URLS=https://yourcompany.sharepoint.com/:x:/g/personal/your_user/your_file?rtime=token
TABLE_PREFIX_EXCEL=excel_